# Team working directories — branches live here, not history.
/.worktrees/

# Never commit secrets.
.env
.env.*
!.env.example
*.pem
*.key
id_rsa*

# Android signing material. No keystore or signing key may enter this
# container at all (see docs/security/signing-and-key-custody.md) — this is
# the last line of defence if that rule is ever ignored, not permission to
# keep a key nearby.
*.jks
*.keystore
*.p12
*.pfx
keystore.properties

# Machine-local Android SDK paths. Not a secret and never has been — ignored
# by long-standing Android convention because the paths differ per machine.
local.properties

# Dependencies and build output. Seeded up front rather than after an agent
# has already staged a virtualenv: the team installs toolchains as it works,
# and the first `git add -A` is too late to notice.
node_modules/
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
target/
vendor/
dist/
build/
*.egg-info/
coverage/
.coverage
.nyc_output/
.gradle/
.next/
.nuxt/
.svelte-kit/
.turbo/
.cache/

# Editor and OS noise.
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Spike build output.
*.jar

# Build artifacts — never commit these. A 4.6MB spike jar was committed by
# accident on 2026-07-20; these rules exist so it cannot happen again.
*.jar
!gradle/wrapper/gradle-wrapper.jar
*.class
build/
.gradle/
*.apk
*.aab

# Personal Claude Code overrides — operator config, not product config.
.claude/settings.local.json
