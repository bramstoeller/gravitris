# Team working directories — branches live here, not history.
/.worktrees/

# Never commit secrets.
.env
.env.*
!.env.example
*.pem
*.key
id_rsa*

# Android signing material. No keystore or signing key may enter this
# container at all (see docs/security/signing-and-key-custody.md, chore/
# threat-model) — this is the last line of defence if that rule is ever
# ignored, not permission to keep a key nearby. The build only ever produces
# unsigned artifacts.
*.jks
*.keystore
*.p12
*.pfx
keystore.properties

# Machine-local Android SDK path. Not a secret and never has been — ignored
# by long-standing Android convention because the path differs per machine.
# This project points Gradle at the SDK via $ANDROID_HOME instead (see
# .env.example), so this file is not expected to exist at all, only guarded
# against.
local.properties

# Dependencies and build output. Seeded up front rather than after an agent
# has already staged a virtualenv: the team installs toolchains as it works,
# and the first `git add -A` is too late to notice.
node_modules/
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
target/
vendor/
dist/
build/
*.egg-info/
coverage/
.coverage
.nyc_output/
.gradle/
.next/
.nuxt/
.svelte-kit/
.turbo/
.cache/

# Android / Gradle build output. `build/` above already catches
# core-sim/build, app/build and buildSrc/build, but the artifact types are
# named explicitly too: a 4.6MB APK was committed by accident before this
# file existed, and it must not be possible to repeat that.
*.apk
*.aab
*.ap_
*.dex
.cxx/
captures/
.kotlin/

# Editor and OS noise.
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Spike build output.
*.jar

# ...except the Gradle wrapper jar, which is the opposite of build output: it
# is a pinned, committed part of the toolchain (its distribution checksum is
# in gradle/wrapper/gradle-wrapper.properties, and CI validates the jar
# itself against Gradle's own known-good list — CHK-6). Without this
# exception `git add -A` silently drops it and `./gradlew` breaks for the
# next clone with no obvious cause — worth naming explicitly rather than
# rediscovering.
!gradle/wrapper/gradle-wrapper.jar

# Personal Claude Code overrides — operator config, not product config.
.claude/settings.local.json
