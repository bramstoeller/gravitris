<?xml version="1.0" encoding="utf-8"?>
<!--
    Belt-and-braces alongside android:allowBackup="false" (S-1,
    docs/security/threat-model.md): on API 31+ this attribute supersedes
    allowBackup for cloud backup and device-to-device transfer, so it must
    say the same thing — exclude everything — rather than being left at its
    permissive default.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapability="false">
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
